# ── LLM Provider ─────────────────────────────────────────────────────
# DSPy 3.x uses litellm under the hood. Set the key for your provider.
# At least one provider key is required to run the AI pipeline.
# See: https://dspy.ai/learn/language_models/

# OpenAI (most common)
OPENAI_API_KEY=

# Anthropic (optional alternative)
# ANTHROPIC_API_KEY=

# Local / Ollama (no key needed — just uncomment and set the base URL)
# OPENAI_API_BASE=http://localhost:11434/v1
